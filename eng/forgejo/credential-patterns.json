[
  {
    "description": "Forgejo, Gitea, GitHub, workflow token, and runner secret environment assignments",
    "pattern": "\\b((?:export\\s+)?(?:FORGEJO_API_TOKEN|FORGEJO_TOKEN|FORGEJO_RUNNER_TOKEN|FORGEJO_RUNNER_SECRET|GITEA_TOKEN|GITHUB_TOKEN|INPUT_TOKEN|INPUTS_TOKEN|FORGEJO__security__INTERNAL_TOKEN)\\s*=\\s*)(?:\"[^\"]*\"|'[^']*'|[^\\s;&|]+)",
    "replacement": "$1<redacted>",
    "flags": "gi"
  },
  {
    "description": "curl user/password arguments",
    "pattern": "((?:^|\\s)(?:-u|--user)(?:=|\\s+))(?:\"[^\"]+:[^\"]*\"|'[^']+:[^']*'|[^\\s\"']+:[^\\s\"']+)",
    "replacement": "$1<redacted>",
    "flags": "gi"
  },
  {
    "description": "Forgejo dump-repo authentication arguments",
    "pattern": "(--auth_(?:username|password|token)(?:=|\\s+))(?:\"[^\"]*\"|'[^']*'|[^\\s;&|]+)",
    "replacement": "$1<redacted>",
    "flags": "gi"
  },
  {
    "description": "Forgejo and runner CLI token or secret arguments",
    "pattern": "(--(?:token|secret)(?:=|\\s+))(?:\"[^\"]*\"|'[^']*'|[^\\s;&|]+)",
    "replacement": "$1<redacted>",
    "flags": "gi"
  },
  {
    "description": "Forgejo CLI password arguments",
    "pattern": "(--password(?:=|\\s+))(?:\"[^\"]*\"|'[^']*'|[^\\s;&|]+)",
    "replacement": "$1<redacted>",
    "flags": "gi"
  },
  {
    "description": "HTTP authorization headers",
    "pattern": "(Authorization:\\s*(?:Bearer|token|Basic)\\s+)[^\\s\"']+",
    "replacement": "$1<redacted>",
    "flags": "gi"
  },
  {
    "description": "Forgejo and Gitea one-time-password headers",
    "pattern": "(X-(?:Forgejo|Gitea)-OTP:\\s*)\\d{6}",
    "replacement": "$1<redacted>",
    "flags": "gi"
  },
  {
    "description": "Credential query parameters",
    "pattern": "([?&](?:token|access_token|auth_token)=)[^&\\s\"'#]+",
    "replacement": "$1<redacted>",
    "flags": "gi"
  },
  {
    "description": "Forgejo actions secret JSON data values",
    "pattern": "((?:actions/secrets)[^\\n]*\"data\"\\s*:\\s*)(?:\"[^\"]*\"|'[^']*'|[^,}\\]\\s]+)",
    "replacement": "$1<redacted>",
    "flags": "gi"
  },
  {
    "description": "JSON credential properties",
    "pattern": "(\"(?:token|access_token|auth_token|auth_username|auth_password|authorization_header|client_secret|remote_password|password)\"\\s*:\\s*)(?:\"[^\"]*\"|'[^']*'|[^,}\\]\\s]+)",
    "replacement": "$1<redacted>",
    "flags": "gi"
  },
  {
    "description": "URL userinfo credentials",
    "pattern": "(https?:\\/\\/)[^@\\s/:]+:[^@\\s/]+@",
    "replacement": "$1<redacted>@",
    "flags": "gi"
  },
  {
    "description": "Runner tokens in config token fields",
    "pattern": "\\b(token\\s*[:=]\\s*)(?:\"[A-Za-z0-9._~+\\/-]{20,}\"|'[A-Za-z0-9._~+\\/-]{20,}'|[A-Za-z0-9._~+\\/-]{20,})",
    "replacement": "$1<redacted>",
    "flags": "gi"
  }
]
