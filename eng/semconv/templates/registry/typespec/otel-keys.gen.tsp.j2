      gen_ai.system                    -> Qyl.OTel.Keys.GenAi.System            = "gen_ai.system"
      gen_ai.usage.input_tokens        -> Qyl.OTel.Keys.GenAi.UsageInputTokens  = "gen_ai.usage.input_tokens"
      db.client.connection.pool.name   -> Qyl.OTel.Keys.Db.ClientConnectionPoolName
