{#-
  Flat JSON attribute registry consumed by @qyl/typespec-qyl-semconv-lint.
  Target: core/specs/emitters/qyl-semconv-lint/data/otel-attribute-registry.json
  Filters upstream registry to `include_prefixes` from weaver.yaml (qyl-relevant
  namespaces only). Complex enum types flatten to "string" — the lint library only
  cares about primitive classification for collision and naming checks.
-#}
[
{%- set first = namespace(v=true) %}
{%- for group in ctx | sort(attribute="root_namespace") %}
{%- if group.root_namespace in params.include_prefixes %}
{%- for attr in group.attributes | sort(attribute="name") %}
{%- set attr_type = (attr.type | string) %}
{%- set normalized_type = "string" if attr_type.startswith("{") else attr_type %}
{%- if not first.v %},{% endif %}
  {
    "name": "{{ attr.name }}",
    "type": "{{ normalized_type }}",
    "stability": "{{ attr.stability | default('experimental') }}",
    "deprecated": {{ (attr.deprecated is not none) | tojson }},
    "group": "{{ group.root_namespace }}"
  }
{%- set first.v = false %}
{%- endfor %}
{%- endif %}
{%- endfor %}
]
