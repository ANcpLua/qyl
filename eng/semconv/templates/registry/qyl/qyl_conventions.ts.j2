{#-
  TypeScript string constants for qyl-owned telemetry attributes.
  Target: packages/qyl-client/src/conventions.ts
  Shape:  SCREAMING_SNAKE_CASE exports grouped by namespace comment.

  semconv_grouped_attributes merges all qyl.* into one group; we sub-group
  by parts[1] of attr.name in the template.
-#}
// <auto-generated/>
// Generated from eng/semconv/model/qyl/ via Weaver
// Do not edit manually - run 'nuke GenerateSemconv'

{% for group in ctx | selectattr("root_namespace", "equalto", "qyl") %}
{% set ns = namespace(current_section='') %}
{% for attr in group.attributes | sort(attribute="name") %}
{% set parts = attr.name.split('.') %}
{% set section = parts[1] if parts | length >= 2 else 'root' %}
{% if section != ns.current_section %}

// qyl.{{ section }}
{% set ns.current_section = section %}
{% endif %}
export const {{ attr.name | screaming_snake_case }} = "{{ attr.name }}";
{% endfor %}
{% endfor %}
