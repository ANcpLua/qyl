<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>Qyl.CollectorAotSmoke</RootNamespace>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Google.Protobuf"/>
    <PackageReference Include="Grpc.Net.Client"/>
    <PackageReference Include="Grpc.Tools" PrivateAssets="all"/>
    <PackageReference Include="OpenTelemetry"/>
    <PackageReference Include="OpenTelemetry.Exporter.OpenTelemetryProtocol"/>
  </ItemGroup>

  <ItemGroup>
    <Protobuf Include="../../../services/qyl.collector/Protos/google/rpc/status.proto"
              ProtoRoot="../../../services/qyl.collector/Protos" GrpcServices="None"/>
    <Protobuf Include="../../../services/qyl.collector/Protos/opentelemetry/proto/common/v1/common.proto"
              ProtoRoot="../../../services/qyl.collector/Protos" GrpcServices="None"/>
    <Protobuf Include="../../../services/qyl.collector/Protos/opentelemetry/proto/resource/v1/resource.proto"
              ProtoRoot="../../../services/qyl.collector/Protos" GrpcServices="None"/>
    <Protobuf Include="../../../services/qyl.collector/Protos/opentelemetry/proto/trace/v1/trace.proto"
              ProtoRoot="../../../services/qyl.collector/Protos" GrpcServices="None"/>
    <Protobuf Include="../../../services/qyl.collector/Protos/opentelemetry/proto/logs/v1/logs.proto"
              ProtoRoot="../../../services/qyl.collector/Protos" GrpcServices="None"/>
    <Protobuf Include="../../../services/qyl.collector/Protos/opentelemetry/proto/metrics/v1/metrics.proto"
              ProtoRoot="../../../services/qyl.collector/Protos" GrpcServices="None"/>
    <Protobuf Include="../../../services/qyl.collector/Protos/opentelemetry/proto/collector/trace/v1/trace_service.proto"
              ProtoRoot="../../../services/qyl.collector/Protos" GrpcServices="Client"/>
    <Protobuf Include="../../../services/qyl.collector/Protos/opentelemetry/proto/collector/logs/v1/logs_service.proto"
              ProtoRoot="../../../services/qyl.collector/Protos" GrpcServices="Client"/>
    <Protobuf Include="../../../services/qyl.collector/Protos/opentelemetry/proto/collector/metrics/v1/metrics_service.proto"
              ProtoRoot="../../../services/qyl.collector/Protos" GrpcServices="Client"/>
  </ItemGroup>

</Project>
