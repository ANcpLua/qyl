<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <Nullable>enable</Nullable>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace></RootNamespace>
    <!-- NoWarn consolidated in eng/build/Directory.Build.props -->
    <NukeRootDirectory>..</NukeRootDirectory>
    <NukeScriptDirectory>..</NukeScriptDirectory>
    <NukeTelemetryVersion>1</NukeTelemetryVersion>
    <NukeExcludeConfig>True</NukeExcludeConfig>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <PropertyGroup Condition="$([MSBuild]::IsOSPlatform('Windows'))">
    <DefineConstants>OS_WINDOWS</DefineConstants>
  </PropertyGroup>
  <PropertyGroup Condition="$([MSBuild]::IsOSPlatform('Linux'))">
    <DefineConstants>OS_LINUX</DefineConstants>
  </PropertyGroup>
  <PropertyGroup Condition="$([MSBuild]::IsOSPlatform('OSX'))">
    <DefineConstants>OS_MAC</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <!-- Core NUKE (versions via CPM) -->
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp"/>
    <PackageReference Include="Nuke.Common"/>
    <PackageReference Include="Nuke.Components"/>
    <!-- Reflected by BuildCollectorSemanticCatalog to emit collector-local semantic key policy. -->
    <PackageReference Include="Qyl.OpenTelemetry.SemanticConventions" PrivateAssets="all"/>
    <PackageReference Include="Qyl.OpenTelemetry.SemanticConventions.Incubating" PrivateAssets="all"/>
    <!-- Transitive security overrides (pulled in by Nuke.Common but with vulnerable
         versions; see Directory.Packages.props for the advisories). -->
    <PackageReference Include="NuGet.Packaging"/>
    <PackageReference Include="System.Security.Cryptography.Xml"/>
  </ItemGroup>

</Project>
