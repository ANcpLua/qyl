<Project Sdk="ANcpLua.NET.Sdk">

  <!--
    Phase C-1 portability harness for the
    Qyl.OpenTelemetry.SemanticConventions.SourceGeneration analyzer pack.

    The generator DLL itself is netstandard2.0 (a Roslyn-load requirement), but
    its EMITTED .cs files are compiled by the consumer's own SDK against the
    consumer's chosen TargetFramework. A consumer on net472 must therefore be
    able to compile the same generated code that a net10.0 consumer compiles.
    That portability is not enforced by the generator's own build — it can only
    be enforced from the consumer side.

    This project compiles the same all-surface fixture under six TFMs
    (net472, netstandard2.0, net6.0, net8.0, net9.0, net10.0). The fixture
    binds attributes, metrics, events, meter factories, and activity helpers
    from both stable and incubating projections, so a green matrix proves more
    than PR-A const-string portability.

    `Directory.Build.props` at the repo root pins <TargetFramework>net10.0,
    so cross-targeting dispatch (which requires TargetFramework empty +
    TargetFrameworks non-empty) is suppressed unless this project explicitly
    clears the singular property. The order of operations in the SDK is:
    Directory.Build.props is imported first and sets TargetFramework=net10.0;
    this project then sets TargetFrameworks; without the explicit clear of
    TargetFramework below, MSBuild would build a single-target net10.0
    project, not the matrix.
  -->

  <PropertyGroup>
    <TargetFramework/>
    <TargetFrameworks>net472;netstandard2.0;net6.0;net8.0;net9.0;net10.0</TargetFrameworks>
    <RootNamespace>Qyl.SemConv.Smoke.Matrix</RootNamespace>
    <IsPackable>false</IsPackable>
    <!-- Library, not an Exe — multi-TFM consumer compilation IS the smoke,
         no need to produce a runnable host on each TFM. -->
    <OutputType>Library</OutputType>
    <!-- NU1507: qyl repo defines two package sources without packageSourceMapping;
         consistent with the rest of the repo.
         NU1903: transitive package advisory; non-blocking for a fixture project.
         MultipleGlobalAnalyzerKeys: emitted only when building from inside a git
         worktree under the source tree (worktree's .globalconfig + the source's
         .globalconfig are both ancestors of this project). Harmless.
         AL0001 / AL0061 / AL0063 / AL0067: consumer-facing analyzer rules that
         only fire under a full hosting wrapper; this is a static fixture
         exercising the generator's emit, not a hosted service. -->
    <NoWarn>$(NoWarn);NU1507;NU1903;MultipleGlobalAnalyzerKeys;AL0001;AL0061;AL0063;AL0067</NoWarn>

    <!-- Documentation generation is on by default at the repo root; the
         fixture is internal-only, so suppress to keep build output clean. -->
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
  </PropertyGroup>

  <!-- net472 has no in-box reference assemblies on non-Windows hosts; the
       NETFramework.ReferenceAssemblies package provides them so the matrix
       can build on macOS/Linux CI without a mono install. VersionOverride is
       used (rather than a global PackageVersion in Directory.Packages.props)
       because this is the only project in the repo that needs net472. -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
    <PackageReference Include="Microsoft.NETFramework.ReferenceAssemblies"
                      VersionOverride="1.0.3"
                      PrivateAssets="all"/>
  </ItemGroup>

  <ItemGroup>
    <!-- UndefineProperties mirrors qyl.semconv.smoke: prevents the consumer's
         per-TFM globals (TargetFramework, RuntimeIdentifier, SelfContained)
         from leaking into the netstandard2.0 generator's recursive evaluation. -->
    <PackageReference Include="Qyl.OpenTelemetry.SemanticConventions.SourceGeneration" PrivateAssets="all"/>
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net472' OR '$(TargetFramework)' == 'netstandard2.0'">
    <PackageReference Include="System.Diagnostics.DiagnosticSource"
                      VersionOverride="$(DotNetRuntimeVersion)"
                      PrivateAssets="all"/>
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net6.0'">
    <PackageReference Include="System.Diagnostics.DiagnosticSource"
                      VersionOverride="8.0.1"
                      PrivateAssets="all"/>
  </ItemGroup>

</Project>
