<Project Sdk="ANcpLua.NET.Sdk">

  <!--
    Phase 2/4 dogfooding consumer for the
    Qyl.OpenTelemetry.SemanticConventions.SourceGeneration analyzer pack.

    Three goals:
      1. Prove the generator can be ProjectReference'd as an Analyzer like
         qyl's other in-tree generators (internal/qyl.instrumentation.generators,
         internal/qyl.collector.storage.generators).
      2. Compile a real net10.0 binary that consumes the emitted symbols
         (DiskAttributes constants, HttpServerMetrics descriptors, SessionEvents
         payload struct).
      3. AOT-publish clean. If a Roslyn-emitted construct introduces an AOT
         warning (e.g., reflection, dynamic codegen), it surfaces here.
  -->

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Qyl.SemConv.Smoke</RootNamespace>
    <IsPackable>false</IsPackable>
    <!-- ANcpLua.NET.Sdk's Common.targets defaults PackAsTool=true for any
         Exe project. PackAsTool reshapes RuntimeIdentifiers to a tool list and
         locks PublishAot=true into NETSDK1207. Force false here so the smoke
         binary can publish as a regular AOT native app. -->
    <PackAsTool>false</PackAsTool>
    <!-- AOT publish is the smoke gate; on by default so the dev-loop catches
         AOT breakage at build time, not just on the explicit publish run.
         EventSourceSupport keeps the EventPipe surface lit so the meter the
         sample creates can still emit (AL0096). -->
    <PublishAot>true</PublishAot>
    <EventSourceSupport>true</EventSourceSupport>
    <!-- NU1507: qyl repo defines two package sources; consistent with other
         qyl projects.
         MultipleGlobalAnalyzerKeys: emitted only when running this build from
         inside a git worktree under the source tree (same as agent 3's
         generator csproj); harmless.
         AL0067: this is a standalone smoke binary, not a service that
         registers a meter via DI. AddMeter is not applicable.
         AL0061/AL0063: same — no DI tracing pipeline, no AddSource() to
         register with. The smoke does set http.request.method + http.route
         via the typed PR-E extensions, which is what AL0061 actually wants;
         the analyzer doesn't recognize source-generated SetXxx calls.
         AL0001: top-level Program.cs is intentional for a one-file smoke;
         the rule only fires under a fuller hosting wrapper. -->
    <NoWarn>$(NoWarn);NU1507;MultipleGlobalAnalyzerKeys;AL0001;AL0061;AL0063;AL0067</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <!-- UndefineProperties prevents the consumer's publish-time globals
         (PublishAot=true, RuntimeIdentifier=osx-arm64) from leaking down
         into the netstandard2.0 analyzer build. Otherwise NETSDK1207 fires
         on the generator csproj during the recursive publish evaluation,
         not on this smoke binary. -->
    <PackageReference Include="Qyl.OpenTelemetry.SemanticConventions.SourceGeneration" PrivateAssets="all"/>
  </ItemGroup>

</Project>
