<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Qyl.Fleet.Hosting</RootNamespace>
    <PackageId>Qyl.Fleet</PackageId>
    <Description>qyl fleet hosting: `AddQylFleet()` registers an in-process reverse proxy that routes dashboard REST + SSE across multiple qyl.collector backends. Zero third-party deps — ships on the shared Microsoft.AspNetCore.App framework.</Description>
    <IsPackable>true</IsPackable>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <!-- Framework reference is shared runtime — no NuGet download, gives us WebApplication,
       IHostedService, IServiceCollection, HttpClientFactory, routing, etc. -->
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App"/>
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\"/>
  </ItemGroup>

</Project>
