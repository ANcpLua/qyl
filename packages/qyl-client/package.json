{
  "name": "@qyl/client",
  "version": "0.1.0",
  "description": "Generated JavaScript/TypeScript client for the qyl observability REST API.",
  "author": "ancplua",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ancplua/qyl.git",
    "directory": "packages/qyl-client"
  },
  "homepage": "https://github.com/ancplua/qyl#readme",
  "keywords": [
    "opentelemetry",
    "observability",
    "genai",
    "llm",
    "qyl"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/generated/api.d.ts",
      "default": "./dist/generated/api.js"
    }
  },
  "files": [
    "dist/**",
    "src/**",
    "schemas/**",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p .",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@typespec/ts-http-runtime": "0.3.5",
    "uri-template": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "18.19.130",
    "typescript": "5.6.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
