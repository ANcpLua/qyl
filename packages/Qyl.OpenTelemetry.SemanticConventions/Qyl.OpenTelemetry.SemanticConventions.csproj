<Project Sdk="ANcpLua.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net10.0;netstandard2.0</TargetFrameworks>
    <TargetFramework></TargetFramework>
    <RootNamespace>Qyl.OpenTelemetry.SemanticConventions</RootNamespace>
    <PackageId>Qyl.OpenTelemetry.SemanticConventions</PackageId>
    <Description>OpenTelemetry Semantic Conventions stable attribute keys (v1.41.0). Generated by Weaver from open-telemetry/semantic-conventions.</Description>
    <Authors>ancplua</Authors>
    <IsPackable>true</IsPackable>
    <VersionPrefix>1.0.0</VersionPrefix>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>

    <!-- All sources are auto-generated .g.cs files. Weaver's html comment format
         emits <p> for paragraph breaks without closing them, which the C# XML-doc
         parser flags as CS1570. The XML is functionally fine for IntelliSense and
         docfx; suppressing the warning class for this generated package is the
         documented "acceptable suppression for source-generated code" pattern. -->
    <NoWarn>$(NoWarn);CS1570</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="schemas/**"/>
  </ItemGroup>

</Project>
