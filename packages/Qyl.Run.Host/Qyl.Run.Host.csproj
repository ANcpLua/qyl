<Project Sdk="ANcpLua.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Qyl.Run.Host</RootNamespace>
    <!-- The runnable launcher. The library (Qyl.Run) stays the packable artifact; this host is not packed. -->
    <IsPackable>false</IsPackable>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../Qyl.Run/Qyl.Run.csproj"/>
  </ItemGroup>

</Project>
