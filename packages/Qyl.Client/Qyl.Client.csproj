<Project Sdk="Microsoft.NET.Sdk">

  <!-- Public REST client SDK — generated by @typespec/http-client-csharp into Generated/src/Generated/**.
       The emitter drops its own scaffold .csproj / .slnx / .NuGet.targets next to the generated sources;
       those are .gitignore'd (see root .gitignore) and superseded by this top-level project. -->

  <PropertyGroup>
    <TargetFrameworks>net10.0;netstandard2.0</TargetFrameworks>
    <TargetFramework></TargetFramework>
    <RootNamespace>Qyl</RootNamespace>
    <PackageId>Qyl.Client</PackageId>
    <Description>Generated .NET client for the Qyl observability REST API.</Description>
    <IsPackable>true</IsPackable>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <!-- Emitter output is pre-formatted and carries its own #nullable directives. -->
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <!-- Emitter output declares every using directive explicitly; implicit usings drag in
         System.Diagnostics (via the SDK's transitive set) and collide with Qyl.OTel.Traces.Trace. -->
    <ImplicitUsings>disable</ImplicitUsings>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <!-- CS1591: missing XML docs on emitter output — the emitter provides partial coverage.
         SCME0002: System.ClientModel's documented experimental-API opt-in; consumers of
         `AuthenticationPolicy.Create` + `ClientPipelineOptions(IConfigurationSection)` are
         expected to acknowledge the experimental status this way. The emitted stubs sit on
         these surfaces; stripping them would break the public client entry points. -->
    <NoWarn>$(NoWarn);CS1591;SCME0002</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Generated/src/Generated/**/*.cs"/>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.ClientModel"/>
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\"/>
  </ItemGroup>

</Project>
