<Project Sdk="ANcpLua.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Qyl.OpenTelemetry.Extensions</RootNamespace>
    <PackageId>Qyl.OpenTelemetry.Extensions</PackageId>
    <Description>OpenTelemetry tracing wiring for qyl collectors with optional metrics pipeline registration.</Description>
    <IsPackable>true</IsPackable>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="ANcpLua.Roslyn.Utilities"/>
    <PackageReference Include="OpenTelemetry.Api"/>
    <PackageReference Include="OpenTelemetry.Exporter.OpenTelemetryProtocol"/>
    <PackageReference Include="OpenTelemetry.Extensions.Hosting"/>
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions"/>
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\"/>
  </ItemGroup>

</Project>
