<Project Sdk="ANcpLua.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Qyl.Host.Mcp</RootNamespace>
    <PackageId>Qyl.Host.Mcp</PackageId>
    <Description>MCP support for the qyl runner — initialize + tools/list readiness, connection-only stdio/HTTP/in-process resources, /runner/mcp passthrough, and OTLP export of the official MCP SDK ActivitySource. Opt-in package; the engine has no MCP assumption.</Description>
    <IsPackable>true</IsPackable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <NoWarn>$(NoWarn);MCPEXP001</NoWarn>
    <!-- IsAotCompatible deliberately NOT claimed: the engine (Qyl.Host) keeps the claim; this
         package leans on the MCP SDK. tests/Qyl.Host.Mcp.AotSmoke publishes a host of this
         package with PublishAot=true (zero IL/AOT warnings; the native binary composes both
         MCP resource kinds), but a compile-time claim waits until a real handshake runs under AOT. -->
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App"/>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="ModelContextProtocol.Core"/>
    <PackageReference Include="OpenTelemetry.Exporter.OpenTelemetryProtocol"/>
    <PackageReference Include="OpenTelemetry.Extensions.Hosting"/>
    <PackageReference Include="Qyl.Api.Contracts"/>
    <ProjectReference Include="..\Qyl.Host\Qyl.Host.csproj"/>
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Qyl.Host.Tests"/>
  </ItemGroup>

</Project>
