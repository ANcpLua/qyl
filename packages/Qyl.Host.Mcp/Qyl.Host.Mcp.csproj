<Project Sdk="ANcpLua.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Qyl.Host.Mcp</RootNamespace>
    <PackageId>Qyl.Host.Mcp</PackageId>
    <Description>MCP support for the qyl runner — initialize + tools/list readiness, connection-only stdio/HTTP/in-process resources, /runner/mcp passthrough, and OTLP export of the official MCP SDK ActivitySource. Opt-in package; the engine has no MCP assumption.</Description>
    <IsPackable>true</IsPackable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <NoWarn>$(NoWarn);MCPEXP001</NoWarn>
    <!-- Verified by tests/Qyl.Host.Mcp.AotSmoke: the PublishAot=true native binary runs LIVE
         initialize + tools/list + tools/call + resources/read handshakes over both the in-process
         and stdio kinds through McpHandshakeProbe/McpClientRegistry/McpContractMapper, with zero
         IL/AOT warnings from this assembly. Remaining publish-time warnings come from
         Qyl.Api.Contracts' generated RunnerMcpResourceContentJsonConverter (reflection-annotated
         Serialize/Deserialize overloads) — an upstream qyl-api-schema generation issue; the calls
         resolve through source-gen options at runtime, and the smoke exercises that exact path. -->
    <IsAotCompatible>true</IsAotCompatible>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App"/>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="ModelContextProtocol.Core"/>
    <PackageReference Include="OpenTelemetry.Exporter.OpenTelemetryProtocol"/>
    <PackageReference Include="OpenTelemetry.Extensions.Hosting"/>
    <PackageReference Include="Qyl.Api.Contracts"/>
    <ProjectReference Include="..\Qyl.Host\Qyl.Host.csproj"/>
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Qyl.Host.Tests"/>
    <InternalsVisibleTo Include="Qyl.Host.Mcp.AotSmoke"/>
  </ItemGroup>

</Project>
