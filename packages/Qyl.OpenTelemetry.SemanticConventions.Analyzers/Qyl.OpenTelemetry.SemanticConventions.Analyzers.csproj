<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Roslyn analyzers must target netstandard2.0 to load in all IDE/SDK host contexts -->
    <TargetFramework>netstandard2.0</TargetFramework>
    <RootNamespace>Qyl.OpenTelemetry.SemanticConventions.Analyzers</RootNamespace>
    <PackageId>Qyl.OpenTelemetry.SemanticConventions.Analyzers</PackageId>
    <Description>Roslyn analyzers that enforce OTel semantic conventions: deprecated-attribute detection, magic-string replacement, and unknown-convention warnings.</Description>
    <IsPackable>true</IsPackable>
    <DevelopmentDependency>true</DevelopmentDependency>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <!-- Analyzer packages ship DLLs under analyzers/ not lib/ -->
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <!-- Opt out of CPM so we can pin Roslyn versions independently -->
    <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <!-- Suppress XML-doc warnings for internal-only types and release tracking for this package -->
    <NoWarn>CS1591;RS2008</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <!-- Roslyn compiler API — PrivateAssets=all so it doesn't leak to consumers -->
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.8.0" PrivateAssets="all" />
    <!-- Workspaces required for CodeFixProvider (Document, CodeFixContext, etc.) -->
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" Version="4.8.0" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" Version="3.3.4" PrivateAssets="all" />
  </ItemGroup>

  <!-- Exclude the Tests/ subdirectory from this library project -->
  <ItemGroup>
    <Compile Remove="Tests/**" />
    <EmbeddedResource Remove="Tests/**" />
    <None Remove="Tests/**" />
  </ItemGroup>

  <ItemGroup>
    <!-- Ship the analyzer DLL under analyzers/dotnet/cs/ inside the nupkg -->
    <None Include="$(OutputPath)\$(AssemblyName).dll"
          Pack="true"
          PackagePath="analyzers/dotnet/cs"
          Visible="false" />
    <!-- deprecated-master.yaml kept for reference; data is baked into DeprecatedAttributeData.g.cs at codegen time -->
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
