<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>Qyl.OpenTelemetry.SemanticConventions.Analyzers.Tests</RootNamespace>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <!-- MTP requires an Exe output for self-hosting -->
    <OutputType>Exe</OutputType>
    <!-- Opt out of CPM so we can pin Roslyn/xunit versions independently -->
    <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <NoWarn>CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Qyl.OpenTelemetry.SemanticConventions.Analyzers.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Roslyn compilation + Workspaces API for building test compilations and applying code fixes -->
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="5.3.0" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" Version="4.8.0" />
    <!-- xUnit v3 with Microsoft Testing Platform integration -->
    <PackageReference Include="xunit.v3.mtp-v2" Version="3.2.2" />
    <PackageReference Include="Microsoft.Testing.Extensions.TrxReport" Version="2.1.0" />
  </ItemGroup>

</Project>
