<Project Sdk="ANcpLua.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Qyl.Host</RootNamespace>
    <PackageId>Qyl.Host</PackageId>
    <Description>qyl's distributed-app host — fluent AppHost-equivalent with Spectre.Console CLI, subprocess orchestration, and deferred endpoint resolution. Zero Aspire deps; ships on the shared Microsoft.AspNetCore.App framework plus Spectre.Console.</Description>
    <IsPackable>true</IsPackable>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- The orchestrator core must stay honestly AOT-clean: no reflection config binding, no resilience
         pipeline, source-generated JSON only. The analyzers keep that claim checked at build time. -->
    <IsAotCompatible>true</IsAotCompatible>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App"/>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Qyl.Api.Contracts"/>
    <PackageReference Include="Spectre.Console"/>
  </ItemGroup>

  <ItemGroup>
    <!-- Owned extension/test assemblies may use the internal composition model. Keeping that
         model internal prevents third-party packages from depending on runner storage shapes. -->
    <InternalsVisibleTo Include="Qyl.Host.Mcp"/>
    <InternalsVisibleTo Include="Qyl.Host.Tests"/>
    <InternalsVisibleTo Include="Qyl.Host.Mcp.AotSmoke"/>
  </ItemGroup>

</Project>
