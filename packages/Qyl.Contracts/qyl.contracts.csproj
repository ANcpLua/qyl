<Project Sdk="ANcpLua.NET.Sdk">

  <PropertyGroup>
    <!-- LEAF project - shared contracts between all qyl components, also published as a NuGet package -->
    <Description>Shared contract types (requests, responses, enums) for the qyl observability platform.</Description>
    <PackageId>Qyl.Contracts</PackageId>
    <RootNamespace>Qyl.Contracts</RootNamespace>
    <Authors>ancplua</Authors>
    <IsPackable>true</IsPackable>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\"/>
  </ItemGroup>

  <!-- BCL only - LEAF project has no external dependencies -->

</Project>
