<Project>
  <PropertyGroup Label="Package Versions">
    <DotNetRuntimeVersion>10.0.7</DotNetRuntimeVersion>
    <MicrosoftExtensionsVersion>10.5.0</MicrosoftExtensionsVersion>
    <MicrosoftExtensionsAiVersion>10.5.0</MicrosoftExtensionsAiVersion>
    <OpenTelemetryVersion>1.15.3</OpenTelemetryVersion>
    <OpenTelemetryAspNetCoreInstrumentationVersion>1.15.1</OpenTelemetryAspNetCoreInstrumentationVersion>
    <DuckDBVersion>1.5.0</DuckDBVersion>
