<Project>
  <PropertyGroup Label="Package Versions">
    <!-- .NET Shared Framework (ships with runtime) -->
    <DotNetRuntimeVersion>10.0.3</DotNetRuntimeVersion>
    <!-- Microsoft.Extensions.* (out-of-band NuGet packages) -->
    <MicrosoftExtensionsVersion>10.3.0</MicrosoftExtensionsVersion>
    <!-- OpenTelemetry -->
    <OpenTelemetryVersion>1.15.0</OpenTelemetryVersion>
    <!-- DuckDB -->
    <DuckDBVersion>1.4.4</DuckDBVersion>
    <!-- gRPC & Protobuf -->
    <GoogleProtobufVersion>3.33.5</GoogleProtobufVersion>
    <GrpcAspNetCoreVersion>2.76.0</GrpcAspNetCoreVersion>
    <GrpcToolsVersion>2.78.0</GrpcToolsVersion>
    <!-- Testing -->
    <XunitVersion>3.2.2</XunitVersion>
    <MicrosoftTestingTrxVersion>2.1.0</MicrosoftTestingTrxVersion>
    <MicrosoftTestingCodeCoverageVersion>18.4.1</MicrosoftTestingCodeCoverageVersion>
    <!-- Analyzers -->
    <MicrosoftCodeAnalysisAnalyzersVersion>3.11.0</MicrosoftCodeAnalysisAnalyzersVersion>
    <MicrosoftCodeAnalysisCSharpVersion>5.0.0</MicrosoftCodeAnalysisCSharpVersion>
    <ANcpLuaRoslynUtilitiesVersion>1.42.0</ANcpLuaRoslynUtilitiesVersion>
    <!-- Microsoft.Agents.AI -->
    <MicrosoftAgentsAbstractionsVersion>1.0.0-rc2</MicrosoftAgentsAbstractionsVersion>
    <MicrosoftAgentsCopilotVersion>1.0.0-preview.260225.1</MicrosoftAgentsCopilotVersion>
    <!-- OpenAI SDK -->
    <OpenAIVersion>2.9.0</OpenAIVersion>
    <!-- MCP -->
    <ModelContextProtocolVersion>1.0.0</ModelContextProtocolVersion>
    <!-- Microsoft.IdentityModel (JWT/JWKS validation for Keycloak) -->
    <MicrosoftIdentityModelVersion>8.16.0</MicrosoftIdentityModelVersion>
    <!-- Build Tooling -->
    <NukeVersion>10.1.0</NukeVersion>
    <!-- Misc -->
    <YamlDotNetVersion>16.3.0</YamlDotNetVersion>
    <SpectreConsoleVersion>0.54.0</SpectreConsoleVersion>
    <!-- PackageDownload -->
    <GitVersionToolVersion>6.5.1</GitVersionToolVersion>
    <ReportGeneratorVersion>5.5.1</ReportGeneratorVersion>
    <VersionizeVersion>2.5.0</VersionizeVersion>
  </PropertyGroup>
</Project>
