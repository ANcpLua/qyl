<Project>
  <PropertyGroup Label="Package Versions">
    <DotNetRuntimeVersion>10.0.7</DotNetRuntimeVersion>
    <MicrosoftExtensionsVersion>10.5.0</MicrosoftExtensionsVersion>
    <MicrosoftExtensionsAiVersion>10.5.2</MicrosoftExtensionsAiVersion>
    <OpenTelemetryVersion>1.15.3</OpenTelemetryVersion>
    <OpenTelemetryAspNetCoreInstrumentationVersion>1.15.1</OpenTelemetryAspNetCoreInstrumentationVersion>
    <DuckDBVersion>1.5.0</DuckDBVersion>
    <GoogleProtobufVersion>3.34.0</GoogleProtobufVersion>
    <GrpcAspNetCoreVersion>2.76.0</GrpcAspNetCoreVersion>
    <GrpcToolsVersion>2.78.0</GrpcToolsVersion>
    <XunitVersion>3.2.2</XunitVersion>
    <MicrosoftTestingTrxVersion>2.1.0</MicrosoftTestingTrxVersion>
    <MicrosoftTestingCodeCoverageVersion>18.5.2</MicrosoftTestingCodeCoverageVersion>
    <MicrosoftCodeAnalysisAnalyzersVersion>5.3.0</MicrosoftCodeAnalysisAnalyzersVersion>
    <MicrosoftCodeAnalysisCSharpVersion>5.3.0</MicrosoftCodeAnalysisCSharpVersion>
    <!-- Single version for all ANcpLua.Roslyn.Utilities.* packages (Utilities + Sources + Polyfills + Testing).
         The packages ship in lockstep; reintroduce a second variable only if they diverge. -->
    <ANcpLuaRoslynUtilitiesVersion>2.2.5</ANcpLuaRoslynUtilitiesVersion>
    <ANcpLuaAnalyzersVersion>1.29.1</ANcpLuaAnalyzersVersion>
    <ANcpLuaAgentsTestingVersion>1.4.1</ANcpLuaAgentsTestingVersion>
    <ANcpLuaAgentsVersion>1.4.1</ANcpLuaAgentsVersion>
    <!-- ANcpLua.Agents.Hosting.OpenAI ships on a slower track than the core +
         Testing pair (latest stable is the 1.4.1-alpha.1 prerelease as of
         2026-05-06). Pin tracks upstream until a stable 1.4.x lands. -->
    <ANcpLuaAgentsHostingOpenAIVersion>1.4.1-alpha.1</ANcpLuaAgentsHostingOpenAIVersion>
    <!-- MAF (Microsoft.Agents.AI.*) versions are sourced from
         framework/ANcpLua.NET.Sdk/src/Build/Common/Version.props, imported
         from Directory.Packages.props before this file. Bumps happen in the SDK
         only; consumers track automatically. -->

    <OpenAIVersion>2.10.0</OpenAIVersion>
    <SystemClientModelVersion>1.11.0</SystemClientModelVersion>
    <ModelContextProtocolVersion>1.2.0</ModelContextProtocolVersion>
    <MicrosoftIdentityModelVersion>8.17.0</MicrosoftIdentityModelVersion>
    <NukeVersion>10.1.0</NukeVersion>
    <NetArchTestVersion>1.3.2</NetArchTestVersion>
    <YamlDotNetVersion>17.1.0</YamlDotNetVersion>
    <SpectreConsoleVersion>0.55.2</SpectreConsoleVersion>
    <GitVersionToolVersion>6.5.1</GitVersionToolVersion>
    <ReportGeneratorVersion>5.5.1</ReportGeneratorVersion>
    <VersionizeVersion>2.5.0</VersionizeVersion>
    <AwesomeAssertionsVersion>9.4.0</AwesomeAssertionsVersion>
    <!-- Transitive security overrides (via Nuke.Common): forced minimums that
         close GHSA-g4vj-cjjj-v7hg (NuGet.Packaging ≥ 6.12.1) and
         GHSA-37gx-xxp4-5rgx / GHSA-w3x6-4m5h-cxqf (System.Security.Cryptography.Xml
         ≥ 9.0.x). -->
    <NuGetPackagingVersion>7.3.1</NuGetPackagingVersion>
    <SystemSecurityCryptographyXmlVersion>9.0.15</SystemSecurityCryptographyXmlVersion>
  </PropertyGroup>
</Project>
