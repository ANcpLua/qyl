<Project Sdk="ANcpLua.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <RootNamespace>Qyl.Instrumentation.Generators</RootNamespace>

    <IsRoslynComponent>true</IsRoslynComponent>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsAotCompatible>false</IsAotCompatible>
    <EnableAotAnalyzer>false</EnableAotAnalyzer>

    <UseInterceptors>true</UseInterceptors>
    <!-- Transitive targets load the generator and its dependency from output. -->
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>

    <!-- Explicit Roslyn references also work under IDE language-server builds. -->
    <DisableImplicitRoslynPackageReference>true</DisableImplicitRoslynPackageReference>
    <InjectTimeProviderPolyfill>false</InjectTimeProviderPolyfill>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="ANcpLua.Roslyn.Utilities.Sources" PrivateAssets="all"/>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp"
                      VersionOverride="5.6.0"
                      PrivateAssets="all"/>
  </ItemGroup>

  <!-- NuGetPackageRoot has no trailing separator when NUGET_PACKAGES is set explicitly. -->
  <PropertyGroup>
    <_ANcpLuaRoslynUtilitiesSourcesRoot>$([MSBuild]::EnsureTrailingSlash('$(NuGetPackageRoot)'))ancplua.roslyn.utilities.sources/$(ANcpLuaRoslynUtilitiesVersion)/contentFiles/cs/any/ANcpLua.Roslyn.Utilities/</_ANcpLuaRoslynUtilitiesSourcesRoot>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="$(_ANcpLuaRoslynUtilitiesSourcesRoot)Polyfills/TimeProvider/**/*.cs"/>
    <Compile Remove="$(_ANcpLuaRoslynUtilitiesSourcesRoot)Caching/ExpiringCache.cs"/>
    <Compile Remove="$(_ANcpLuaRoslynUtilitiesSourcesRoot)Text/ByteSize.cs"/>
  </ItemGroup>
  <ItemGroup>
    <Using Include="ANcpLua.Roslyn.Utilities"/>
    <Using Include="ANcpLua.Roslyn.Utilities.Analyzers"/>
    <Using Include="ANcpLua.Roslyn.Utilities.Models"/>
    <Using Include="ANcpLua.Roslyn.Utilities.Matching"/>
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="AnalyzerReleases\AnalyzerReleases.Shipped.md"/>
    <AdditionalFiles Include="AnalyzerReleases\AnalyzerReleases.Unshipped.md"/>
  </ItemGroup>
</Project>
