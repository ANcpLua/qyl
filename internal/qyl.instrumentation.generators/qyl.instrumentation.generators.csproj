<Project Sdk="ANcpLua.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <!-- netstandard2.0 defaults to C# 7.3, but we use modern features (required, init, file-scoped namespaces) -->
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <RootNamespace>Qyl.Instrumentation.Generators</RootNamespace>

    <!-- Analyzer/Generator settings -->
    <IsRoslynComponent>true</IsRoslynComponent>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- AOT not supported for netstandard2.0 (required for Roslyn analyzer compatibility) -->
    <IsAotCompatible>false</IsAotCompatible>
    <EnableAotAnalyzer>false</EnableAotAnalyzer>

    <!-- Enable C# 12 interceptors (auto-suppresses RSEXPERIMENTAL002) -->
    <UseInterceptors>true</UseInterceptors>
    <!-- Copy NuGet dependencies to output so transitive .targets can include them -->
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>

    <!--
      Self-describe the Roslyn reference instead of letting ANcpLua.NET.Sdk/SourceGenerators.props
      inject it via name-matching ("*generator*"). The SDK's implicit injection is fragile under
      IDE language servers: if the LSP evaluates Sdk.props before Common.props imports have run,
      Microsoft.CodeAnalysis.* disappears from the whole compilation even though `dotnet build` works.
      Opting out below + an explicit PackageReference makes this project self-contained.
    -->
    <DisableImplicitRoslynPackageReference>true</DisableImplicitRoslynPackageReference>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="ANcpLua.Roslyn.Utilities.Sources" PrivateAssets="all"/>
    <!-- VersionOverride bypasses Directory.Packages.props CPM (the package isn't centrally listed). -->
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp"
                      VersionOverride="5.0.0"
                      PrivateAssets="all"/>
  </ItemGroup>
  <ItemGroup>
    <Using Include="ANcpLua.Roslyn.Utilities"/>
    <Using Include="ANcpLua.Roslyn.Utilities.Analyzers"/>
    <Using Include="ANcpLua.Roslyn.Utilities.Models"/>
    <Using Include="ANcpLua.Roslyn.Utilities.Matching"/>
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="AnalyzerReleases\AnalyzerReleases.Shipped.md"/>
    <AdditionalFiles Include="AnalyzerReleases\AnalyzerReleases.Unshipped.md"/>
  </ItemGroup>
</Project>
