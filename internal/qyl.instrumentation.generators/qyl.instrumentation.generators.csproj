<Project Sdk="ANcpLua.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <!-- netstandard2.0 defaults to C# 7.3, but we use modern features (required, init, file-scoped namespaces) -->
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <RootNamespace>Qyl.Instrumentation.Generators</RootNamespace>

    <!-- Analyzer/Generator settings -->
    <IsRoslynComponent>true</IsRoslynComponent>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- AOT not supported for netstandard2.0 (required for Roslyn analyzer compatibility) -->
    <IsAotCompatible>false</IsAotCompatible>
    <EnableAotAnalyzer>false</EnableAotAnalyzer>

    <!-- Enable C# 12 interceptors (auto-suppresses RSEXPERIMENTAL002) -->
    <UseInterceptors>true</UseInterceptors>
    <!-- Copy NuGet dependencies to output so transitive .targets can include them -->
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>

    <!-- self-describe the Roslyn reference; SDK name-matching injection is fragile under IDE LSPs -->
    <DisableImplicitRoslynPackageReference>true</DisableImplicitRoslynPackageReference>
    <InjectTimeProviderPolyfill>false</InjectTimeProviderPolyfill>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="ANcpLua.Roslyn.Utilities.Sources" PrivateAssets="all"/>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp"
                      VersionOverride="5.6.0"
                      PrivateAssets="all"/>
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="$(NuGetPackageRoot)ancplua.roslyn.utilities.sources/$(ANcpLuaRoslynUtilitiesVersion)/contentFiles/cs/any/ANcpLua.Roslyn.Utilities/Polyfills/TimeProvider/**/*.cs"/>
    <Compile Remove="$(NuGetPackageRoot)ancplua.roslyn.utilities.sources/$(ANcpLuaRoslynUtilitiesVersion)/contentFiles/cs/any/ANcpLua.Roslyn.Utilities/Caching/ExpiringCache.cs"/>
    <Compile Remove="$(NuGetPackageRoot)ancplua.roslyn.utilities.sources/$(ANcpLuaRoslynUtilitiesVersion)/contentFiles/cs/any/ANcpLua.Roslyn.Utilities/Text/ByteSize.cs"/>
  </ItemGroup>
  <ItemGroup>
    <Using Include="ANcpLua.Roslyn.Utilities"/>
    <Using Include="ANcpLua.Roslyn.Utilities.Analyzers"/>
    <Using Include="ANcpLua.Roslyn.Utilities.Models"/>
    <Using Include="ANcpLua.Roslyn.Utilities.Matching"/>
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="AnalyzerReleases\AnalyzerReleases.Shipped.md"/>
    <AdditionalFiles Include="AnalyzerReleases\AnalyzerReleases.Unshipped.md"/>
  </ItemGroup>
</Project>
