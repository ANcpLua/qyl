<Project Sdk="ANcpLua.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Qyl.Instrumentation</RootNamespace>
    <!-- Required for source generator interceptors -->
    <InterceptorsNamespaces>$(InterceptorsNamespaces);Qyl.Instrumentation.Generators</InterceptorsNamespaces>
  </PropertyGroup>

  <ItemGroup>
    <Using Include="ANcpLua.Roslyn.Utilities"/>
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Qyl.Collector.Tests"/>
  </ItemGroup>

  <ItemGroup>
    <!-- ASP.NET Core -->
    <PackageReference Include="Microsoft.AspNetCore.OpenApi"/>
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions"/>
    <PackageReference Include="Microsoft.Extensions.Http.Resilience"/>
    <PackageReference Include="Microsoft.Extensions.ServiceDiscovery"/>
    <PackageReference Include="ANcpLua.Roslyn.Utilities"/>
    <PackageReference Include="ANcpLua.Agents"/>

    <!-- Microsoft.Extensions.AI for IChatClient instrumentation -->
    <PackageReference Include="Microsoft.Extensions.AI"/>

    <!-- Microsoft.Agents.AI for AIAgentBuilder + UseLogging + UseOpenTelemetry (agent-layer) -->
    <PackageReference Include="Microsoft.Agents.AI.Hosting"/>

    <!-- ModelContextProtocol for IMcpServerBuilder + filter surface (Mcp/QylMcpServerInstrumentation) -->
    <PackageReference Include="ModelContextProtocol"/>

    <!-- .NET 10 Telemetry (Enrichment, Sampling) -->
    <PackageReference Include="Microsoft.Extensions.Telemetry"/>
    <PackageReference Include="Microsoft.Extensions.Telemetry.Abstractions"/>

    <!-- OpenTelemetry -->
    <PackageReference Include="OpenTelemetry.Exporter.OpenTelemetryProtocol"/>
    <PackageReference Include="OpenTelemetry.Extensions.Hosting"/>
    <PackageReference Include="OpenTelemetry.Instrumentation.AspNetCore"/>
    <PackageReference Include="OpenTelemetry.Instrumentation.Http"/>
    <PackageReference Include="OpenTelemetry.Instrumentation.Runtime"/>
  </ItemGroup>

  <!-- MSBuild property toggles for source generator pipelines -->
  <ItemGroup>
    <CompilerVisibleProperty Include="QylGenAi"/>
    <CompilerVisibleProperty Include="QylDatabase"/>
    <CompilerVisibleProperty Include="QylAgent"/>
    <CompilerVisibleProperty Include="QylTraced"/>
    <CompilerVisibleProperty Include="QylMeter"/>
  </ItemGroup>

  <ItemGroup>
    <!-- Shared types -->
    <ProjectReference Include="../../packages/Qyl.Contracts/qyl.contracts.csproj"/>
    <ProjectReference Include="../../packages/Qyl.SemanticConventions/Qyl.SemanticConventions.csproj"/>
    <ProjectReference Include="../../packages/Qyl.OpenTelemetry.SemanticConventions/Qyl.OpenTelemetry.SemanticConventions.csproj"/>
    <ProjectReference Include="../../packages/Qyl.OpenTelemetry.SemanticConventions.Incubating/Qyl.OpenTelemetry.SemanticConventions.Incubating.csproj"/>

    <!-- Source generator for auto-instrumentation -->
    <ProjectReference Include="../../internal/qyl.instrumentation.generators/qyl.instrumentation.generators.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false"/>
    <!-- Deprecated / magic-string / unknown-convention OTel diagnostics -->
    <ProjectReference Include="../../packages/Qyl.OpenTelemetry.SemanticConventions.Analyzers/Qyl.OpenTelemetry.SemanticConventions.Analyzers.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false"
                      PrivateAssets="all"/>
  </ItemGroup>

</Project>
