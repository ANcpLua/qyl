{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Corpus target",
  "type": "object",
  "required": ["id", "name", "path", "kind", "expected_build", "expected_tests"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "path": { "type": "string" },
    "clone_url": { "type": "string" },
    "solution": { "type": ["string", "null"] },
    "kind": { "type": "string" },
    "expected_build": { "type": "boolean" },
    "expected_tests": { "type": "boolean" },
    "coverage_required": { "type": "boolean" },
    "telemetry_required": { "type": "boolean" },
    "ground_truth_label": { "type": ["string", "null"] },
    "ground_truth_source": { "type": "string" }
  }
}
