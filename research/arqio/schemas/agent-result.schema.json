{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Evaluation target result",
  "type": "object",
  "required": ["target_id", "run_id", "iteration", "started_at", "finished_at", "build", "test", "coverage", "classification"],
  "properties": {
    "target_id": { "type": "string" },
    "run_id": { "type": "string" },
    "iteration": { "type": "integer" },
    "git": { "type": "object" },
    "build": { "type": "object" },
    "test": { "type": "object" },
    "coverage": { "type": "object" },
    "telemetry": { "type": "object" },
    "classification": { "type": "object" },
    "logs": { "type": "object" }
  }
}
