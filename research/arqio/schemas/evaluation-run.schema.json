{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Evaluation run",
  "type": "object",
  "required": ["run_id", "targets", "results"],
  "properties": {
    "run_id": { "type": "string" },
    "started_at": { "type": "string" },
    "finished_at": { "type": "string" },
    "targets": { "type": "array" },
    "results": { "type": "array" }
  }
}
