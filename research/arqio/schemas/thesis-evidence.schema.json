{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Thesis evidence index",
  "type": "object",
  "required": ["run_id", "artifacts"],
  "properties": {
    "run_id": { "type": "string" },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "kind", "description"],
        "properties": {
          "path": { "type": "string" },
          "kind": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    }
  }
}
