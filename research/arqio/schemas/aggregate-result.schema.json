{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Aggregate evaluation result",
  "type": "object",
  "required": ["run_id", "target_count", "results"],
  "properties": {
    "run_id": { "type": "string" },
    "target_count": { "type": "integer" },
    "build_success_rate": { "type": "number" },
    "test_success_rate": { "type": "number" },
    "coverage_available_count": { "type": "integer" },
    "telemetry_available_count": { "type": "integer" },
    "results": { "type": "array" }
  }
}
