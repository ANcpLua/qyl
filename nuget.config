<?xml version="1.0" encoding="utf-8"?>
<!--
  NuGet config for the qyl monorepo.

  packageSourceMapping pins every package to nuget.org. With a single source this is a
  defensive supply-chain lock (a later-added source can't silently satisfy an already
  resolved package), not a hard requirement — the missing-mapping diagnostic (NU1507)
  only fires once more than one source is configured. When you add a second feed (e.g. a
  local feed for beta packing), add its <packageSource>/<package pattern> mapping here in
  the same change, or restore fails (NU1100/NU1507). No NuGet version is named on purpose:
  version-specific claims in comments rot and cause double work when the toolchain moves.
-->
<configuration>
    <packageSources>
        <clear />
        <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    </packageSources>
    <packageSourceMapping>
        <packageSource key="nuget.org">
            <package pattern="*" />
        </packageSource>
    </packageSourceMapping>
</configuration>
