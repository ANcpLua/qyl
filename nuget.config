<?xml version="1.0" encoding="utf-8"?>
<!--
  NuGet config for the qyl monorepo.

  github-O-ANcppLua sources O-ANcppLua-published NuGets (currently
  Nuke.OpenTelemetry.Conventions; future ANcpLua.OtelConventions.Api server-side
  artifacts). Credentials come from the env vars below — set by GitHub Actions
  automatically via secrets.GITHUB_TOKEN, or for offline dev export GITHUB_ACTOR
  + GITHUB_PACKAGES_TOKEN (a PAT with read:packages) before invoking ./eng/build.sh.

  packageSourceMapping is required with central package management + multiple
  package sources: NuGet 6.13+ escalates the missing-mapping diagnostic from
  warning NU1507 to error NU1507, which makes `dotnet publish` fail even
  though restore itself succeeds. Pinning each prefix to a single source
  resolves the ambiguity — `*` falls through to nuget.org, and only the
  O-ANcppLua-published prefixes route to GitHub Packages.
-->
<configuration>
    <packageSources>
        <clear />
        <add key="github-O-ANcppLua" value="https://nuget.pkg.github.com/O-ANcppLua/index.json" protocolVersion="3" />
        <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    </packageSources>
    <packageSourceMapping>
        <packageSource key="nuget.org">
            <package pattern="*" />
        </packageSource>
        <packageSource key="github-O-ANcppLua">
            <package pattern="Nuke.OpenTelemetry.Conventions" />
            <package pattern="ANcpLua.OtelConventions.*" />
        </packageSource>
    </packageSourceMapping>
    <packageSourceCredentials>
        <github-O-ANcppLua>
            <add key="Username" value="%GITHUB_ACTOR%" />
            <add key="ClearTextPassword" value="%GITHUB_PACKAGES_TOKEN%" />
        </github-O-ANcppLua>
    </packageSourceCredentials>
</configuration>
