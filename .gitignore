# ═══════════════════════════════════════════════════════════════════════════════════
# qyl — .gitignore
# ═══════════════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────────────
# .NET Artifacts (Modern Layout - see Directory.Build.props)
# All build output goes to /artifacts via UseArtifactsOutput=true
# ───────────────────────────────────────────────────────────────────────────────────
artifacts/

# Legacy layout (in case UseArtifactsOutput is disabled)
[Bb]in/
[Oo]bj/
[Oo]ut/

# ───────────────────────────────────────────────────────────────────────────────────
# .NET Build & Publish
# ───────────────────────────────────────────────────────────────────────────────────
*.user
*.rsuser
*.suo
*.userosscache
*.sln.docstates
*.userprefs
project.lock.json
project.fragment.lock.json
packages/
*.nupkg
*.snupkg

# NuGet
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# ───────────────────────────────────────────────────────────────────────────────────
# IDE — Visual Studio / Rider / VS Code
# ───────────────────────────────────────────────────────────────────────────────────
.vs/
.vscode/
.idea/
*.DotSettings.user
launchSettings.json

# ───────────────────────────────────────────────────────────────────────────────────
# Node.js / Frontend (qyl.dashboard)
# ───────────────────────────────────────────────────────────────────────────────────
node_modules/
dist/
.cache/
.parcel-cache/
.vite/
*.local

# ───────────────────────────────────────────────────────────────────────────────────
# OS Generated
# ───────────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ───────────────────────────────────────────────────────────────────────────────────
# Logs & Temporary Files
# ───────────────────────────────────────────────────────────────────────────────────
*.log
*.tmp
*.temp
logs/
*.pid
*.seed
*.pid.lock

# ───────────────────────────────────────────────────────────────────────────────────
# Test Results
# ───────────────────────────────────────────────────────────────────────────────────
TestResults/
coverage/
*.coverage
*.coveragexml

# ───────────────────────────────────────────────────────────────────────────────────
# DuckDB Database Files (qyl.collector)
# ───────────────────────────────────────────────────────────────────────────────────
*.db
*.db.wal
*.duckdb
*.duckdb.wal

# ───────────────────────────────────────────────────────────────────────────────────
# Secrets & Environment (NEVER commit)
# ───────────────────────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
appsettings.*.json
!appsettings.json
!appsettings.Development.json.example
secrets.json
*.pfx
*.key
*.pem
