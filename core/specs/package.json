{
  "name": "@qyl/typespec-schemas",
  "version": "2.0.0",
  "private": true,
  "description": "TypeSpec schemas for qyl observability platform",
  "scripts": {
    "compile": "tsp compile main.tsp && node scripts/patch-emitted-csharp.mjs",
    "watch": "tsp compile main.tsp --watch",
    "format": "tsp format **/*.tsp",
    "lint": "tsp compile main.tsp --warn-as-error"
  },
  "devDependencies": {
    "@qyl/typespec-emit-csharp": "file:./emitters/csharp",
    "@qyl/typespec-emit-duckdb": "file:./emitters/duckdb",
    "@qyl/typespec-emit-ts-types": "file:./emitters/ts-types",
    "@typespec/compiler": "1.11.0",
    "@typespec/events": "0.81.0",
    "@typespec/http": "1.11.0",
    "@typespec/json-schema": "1.11.0",
    "@typespec/openapi": "1.11.0",
    "@typespec/openapi3": "1.11.0",
    "@typespec/rest": "0.81.0",
    "@typespec/sse": "0.81.0",
    "@typespec/streams": "0.81.0",
    "@typespec/versioning": "0.81.0",
    "openapi-typescript": "^7.10.1"
  },
  "dependencies": {
    "@azure-tools/typespec-azure-core": "^0.67.0",
    "@azure-tools/typespec-client-generator-core": "^0.67.2",
    "@typespec/http-client-csharp": "^1.0.0-alpha.20260420.8",
    "@typespec/http-client-js": "^0.14.1",
    "@typespec/xml": "^0.81.0"
  }
}
