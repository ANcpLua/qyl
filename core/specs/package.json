{
  "name": "@qyl/typespec-schemas",
  "version": "2.0.0",
  "private": true,
  "description": "TypeSpec schemas for qyl observability platform",
  "scripts": {
    "compile": "tsp compile main.tsp && node scripts/patch-emitted-csharp.mjs && node scripts/patch-emitted-ts-client.mjs",
    "watch": "tsp compile main.tsp --watch",
    "format": "tsp format **/*.tsp",
    "lint": "tsp compile main.tsp --warn-as-error"
  },
  "devDependencies": {
    "@qyl/typespec-emit-csharp": "file:./emitters/csharp",
    "@qyl/typespec-emit-duckdb": "file:./emitters/duckdb",
    "@qyl/typespec-emit-ts-types": "file:./emitters/ts-types",
    "@qyl/typespec-qyl-semconv-lint": "file:./emitters/qyl-semconv-lint",
    "@typespec/compiler": "1.12.0-dev.6",
    "@typespec/events": "0.82.0-dev.2",
    "@typespec/http": "1.12.0-dev.5",
    "@typespec/http-server-csharp": "0.58.0-alpha.28-dev.4",
    "@typespec/json-schema": "1.12.0-dev.2",
    "@typespec/openapi": "1.12.0-dev.2",
    "@typespec/openapi3": "1.12.0-dev.4",
    "@typespec/rest": "0.82.0-dev.3",
    "@typespec/sse": "0.82.0-dev.2",
    "@typespec/streams": "0.82.0-dev.2",
    "@typespec/versioning": "0.82.0-dev.2",
    "openapi-typescript": "7.13.0"
  },
  "dependencies": {
    "@azure-tools/typespec-azure-core": "^0.68.0-dev.5",
    "@azure-tools/typespec-client-generator-core": "^0.68.0-dev.18",
    "@o-ancpplua/otel-conventions-api": "0.1.0",
    "@typespec/http-client-csharp": "^1.0.0-alpha.20260501.5",
    "@typespec/http-client-js": "^0.14.1",
    "@typespec/xml": "^0.82.0-dev.2"
  }
}
