{
  "name": "@qyl/typespec-emit-ts-types",
  "version": "0.1.0",
  "description": "qyl-native TypeSpec emitter for TypeScript types (branded scalars + interfaces)",
  "type": "module",
  "main": "dist/index.js",
  "tspMain": "lib/main.tsp",
  "exports": {
    ".": {
      "typespec": "./lib/main.tsp",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "prepare": "tsc -p ."
  },
  "peerDependencies": {
    "@typespec/compiler": "^1.11.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typespec/compiler": "1.11.0",
    "typescript": "~5.6.0"
  }
}
