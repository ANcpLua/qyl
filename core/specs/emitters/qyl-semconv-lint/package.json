{
  "name": "@qyl/typespec-qyl-semconv-lint",
  "version": "0.1.0",
  "description": "TypeSpec library that lints qyl-owned telemetry attributes against OTel semconv.",
  "type": "module",
  "main": "dist/index.js",
  "tspMain": "lib/main.tsp",
  "exports": {
    ".": {
      "typespec": "./lib/main.tsp",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "prepare": "tsc -p .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@typespec/compiler": "^1.11.0"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@typespec/compiler": "1.11.0",
    "typescript": "5.6.3",
    "vitest": "2.1.9"
  }
}
