<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>Qyl.Sdk.Conformance</RootNamespace>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PublishAot>true</PublishAot>
    <InvariantGlobalization>true</InvariantGlobalization>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Qyl.Sdk" GeneratePathProperty="true" />
  </ItemGroup>

  <Target Name="VerifyReleasedQylSdkPackage" BeforeTargets="CoreCompile">
    <Error Condition="'$(PkgQyl_Sdk)' == ''"
           Text="Qyl.Sdk.Conformance must compile against the centrally pinned released Qyl.Sdk NuGet package." />
  </Target>

</Project>
