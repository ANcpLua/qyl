<Project Sdk="ANcpLua.NET.Sdk">
  <PropertyGroup>
    <IsTestProject>true</IsTestProject>
    <OutputType>Exe</OutputType>
    <!-- Project name contains "generators" so ANcpLua.NET.Sdk auto-detects this as a
         Roslyn component and would pin Microsoft.CodeAnalysis.CSharp to 5.0.0.
         Opt out so the explicit 5.3.0 override below can reach analyzer test code. -->
    <SourceGeneratorRoslynVersion></SourceGeneratorRoslynVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="xunit.v3.mtp-v2"/>
    <PackageReference Include="Microsoft.Testing.Extensions.TrxReport"/>
    <PackageReference Include="Microsoft.Testing.Extensions.CodeCoverage"/>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" VersionOverride="$(MicrosoftCodeAnalysisCSharpVersion)"/>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\qyl.instrumentation.generators\qyl.instrumentation.generators.csproj"/>
  </ItemGroup>
</Project>
