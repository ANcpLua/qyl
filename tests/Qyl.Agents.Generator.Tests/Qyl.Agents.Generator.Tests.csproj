<Project Sdk="ANcpLua.NET.Sdk">
  <PropertyGroup>
    <IsTestProject>true</IsTestProject>
    <OutputType>Exe</OutputType>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="xunit.v3.mtp-v2"/>
    <PackageReference Include="ANcpLua.Roslyn.Utilities.Testing"/>
    <!-- ANcpLua.Roslyn.Utilities.Testing pulls CSharp 5.0.0 → Common 5.0.0, but the generator
         project references CSharp.Workspaces 5.3.0 → Common 5.3.0. Pin Common 5.3.0 directly
         here to unify the graph; NU1107 otherwise. -->
    <PackageReference Include="Microsoft.CodeAnalysis.Common" VersionOverride="$(MicrosoftCodeAnalysisCSharpVersion)"/>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Qyl.Agents.Generator\Qyl.Agents.Generator.csproj"/>
    <ProjectReference Include="..\..\src\Qyl.Agents.Abstractions\Qyl.Agents.Abstractions.csproj"/>
  </ItemGroup>
</Project>
