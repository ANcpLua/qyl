<Project Sdk="ANcpLua.NET.Sdk">
  <PropertyGroup>
    <IsTestProject>true</IsTestProject>
    <OutputType>Exe</OutputType>
    <!-- Project name contains "Generator" so ANcpLua.NET.Sdk auto-detects this as
         a Roslyn component and would pin Microsoft.CodeAnalysis.CSharp to 5.0.0.
         This is a test project that needs the 5.3.0 graph (Workspaces 5.3.0 → Common 5.3.0);
         opt out of the auto-pin so the implicit net10.0 Roslyn reference wins. -->
    <SourceGeneratorRoslynVersion></SourceGeneratorRoslynVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="xunit.v3.mtp-v2"/>
    <PackageReference Include="Microsoft.Testing.Extensions.TrxReport"/>
    <PackageReference Include="Microsoft.Testing.Extensions.CodeCoverage"/>
    <PackageReference Include="ANcpLua.Roslyn.Utilities.Testing"/>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Qyl.Agents.Generator\Qyl.Agents.Generator.csproj"/>
    <ProjectReference Include="..\..\src\Qyl.Agents.Abstractions\Qyl.Agents.Abstractions.csproj"/>
  </ItemGroup>
</Project>
