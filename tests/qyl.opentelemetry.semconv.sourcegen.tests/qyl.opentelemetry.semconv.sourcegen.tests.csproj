<Project Sdk="ANcpLua.NET.Sdk.Test">

  <PropertyGroup>
    <RootNamespace>Qyl.OpenTelemetry.SemanticConventions.SourceGeneration.Tests</RootNamespace>
    <AssemblyName>Qyl.OpenTelemetry.SemanticConventions.SourceGeneration.Tests</AssemblyName>
    <OutputType>Exe</OutputType>

    <!-- NU1507: qyl repo defines two package sources without packageSourceMapping
         (consistent with other publishable qyl packages).
         MultipleGlobalAnalyzerKeys: emitted only when running this build from
         inside a git worktree under the source tree; harmless. -->
    <NoWarn>$(NoWarn);NU1507;MultipleGlobalAnalyzerKeys</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="xunit.v3.mtp-v2"/>
    <PackageReference Include="Microsoft.Testing.Extensions.TrxReport"/>
    <PackageReference Include="ANcpLua.Roslyn.Utilities.Testing"/>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference
      Include="..\..\packages\Qyl.OpenTelemetry.SemanticConventions.SourceGeneration.Generator\Qyl.OpenTelemetry.SemanticConventions.SourceGeneration.Generator.csproj"/>
  </ItemGroup>

  <ItemGroup>
    <!-- Phase 2/4 byte-identity snapshots. The .txt extension keeps the
         compiler from picking these up as C# source; tests load the bytes
         via Assembly.GetManifestResourceStream using the stable LogicalName.
         qyl.<prefix>.expected.txt     → PR-A attribute prefixes.
         qyl.<surface>.<key>.expected.txt → PR-B/C/D/E surface generators. -->
    <EmbeddedResource Include="Snapshots\qyl.disk.expected.txt"
                      LogicalName="qyl.disk.expected.txt"/>
    <EmbeddedResource Include="Snapshots\qyl.http.expected.txt"
                      LogicalName="qyl.http.expected.txt"/>
    <EmbeddedResource Include="Snapshots\qyl.network.expected.txt"
                      LogicalName="qyl.network.expected.txt"/>
    <EmbeddedResource Include="Snapshots\qyl.metrics.http-server.expected.txt"
                      LogicalName="qyl.metrics.http-server.expected.txt"/>
    <EmbeddedResource Include="Snapshots\qyl.events.session.expected.txt"
                      LogicalName="qyl.events.session.expected.txt"/>
    <EmbeddedResource Include="Snapshots\qyl.meters.http-server.expected.txt"
                      LogicalName="qyl.meters.http-server.expected.txt"/>
    <EmbeddedResource Include="Snapshots\qyl.activities.http.expected.txt"
                      LogicalName="qyl.activities.http.expected.txt"/>
  </ItemGroup>

</Project>
