<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>Qyl.Agents</RootNamespace>

    <Description>Marker attributes for Qyl.Agents source generator: [McpServer] and [Tool].</Description>
    <PackageTags>qyl;agents;mcp;source-generator;attributes</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <Using Include="System"/>
  </ItemGroup>
  <!-- netstandard2.0 polyfills (IsExternalInit, RequiredMember, CompilerFeatureRequired,
       SetsRequiredMembers, Experimental) — contentFiles drop from the focused
       Polyfills-only package. PrivateAssets="all" keeps it out of the published nupkg. -->
  <ItemGroup>
    <PackageReference Include="ANcpLua.Roslyn.Utilities.Polyfills" PrivateAssets="all"/>
  </ItemGroup>
</Project>
