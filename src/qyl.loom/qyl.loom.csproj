<Project Sdk="ANcpLua.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <OutputType>Exe</OutputType>
    <RootNamespace>Qyl.Loom</RootNamespace>
    <LangVersion>14</LangVersion>
    <InvariantGlobalization>true</InvariantGlobalization>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <InterceptorsNamespaces>$(InterceptorsNamespaces);Qyl.Instrumentation.Generators</InterceptorsNamespaces>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App"/>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Agents.AI.Hosting"/>
    <PackageReference Include="Microsoft.Extensions.AI"/>
    <PackageReference Include="Qyl.Agents.Abstractions"/>
    <PackageReference Include="Qyl.Agents"/>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\qyl.instrumentation\qyl.instrumentation.csproj"/>
    <ProjectReference Include="..\qyl.contracts\qyl.contracts.csproj"/>
    <ProjectReference Include="..\qyl.instrumentation.generators\qyl.instrumentation.generators.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false"
                      PrivateAssets="all"/>
  </ItemGroup>
</Project>
