<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Qyl.Agents</RootNamespace>

    <Description>Runtime for Qyl.Agents source generator: MCP transport, DI extensions, hosting.</Description>
    <PackageTags>qyl;agents;mcp;opentelemetry;hosting</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App"/>
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Qyl.Agents.Tests"/>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Qyl.Agents.Abstractions\Qyl.Agents.Abstractions.csproj"/>
  </ItemGroup>
</Project>
