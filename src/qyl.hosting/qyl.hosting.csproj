<Project Sdk="ANcpLua.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <OutputType>Library</OutputType>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Qyl.Hosting</RootNamespace>
    <Description>GenAI-native application orchestration - the better AppHost</Description>
    <IsAotCompatible>true</IsAotCompatible>
    <JsonSerializerIsReflectionEnabledByDefault>false</JsonSerializerIsReflectionEnabledByDefault>
    <!-- Required for source generator interceptors -->
    <InterceptorsNamespaces>$(InterceptorsNamespaces);Qyl.ServiceDefaults.Generator</InterceptorsNamespaces>
  </PropertyGroup>

  <!-- No direct PackageReferences needed: hosting + config come transitively from qyl.servicedefaults -->

  <ItemGroup>
    <!-- Service defaults (attributes + runtime helpers, transitively provides qyl.protocol) -->
    <ProjectReference Include="../qyl.servicedefaults/qyl.servicedefaults.csproj"/>

    <!-- Source generator (compile-time instrumentation) -->
    <ProjectReference Include="../qyl.servicedefaults.generator/qyl.servicedefaults.generator.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false"/>
  </ItemGroup>

</Project>
