<Project Sdk="ANcpLua.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>

    <!-- Set up the NuGet package to be an MCP server -->
    <PackAsTool>true</PackAsTool>
    <PackageType>McpServer</PackageType>
    <!-- Dashed binary name for 'dotnet tool install -g Qyl.Mcp' → 'qyl-mcp' on PATH -->
    <ToolCommandName>qyl-mcp</ToolCommandName>
    <!-- Override global IsPackable=false in Directory.Build.props; qyl.mcp ships to NuGet -->
    <IsPackable>true</IsPackable>
    <InvariantGlobalization>true</InvariantGlobalization>

    <!-- Package metadata -->
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageId>Qyl.Mcp</PackageId>
    <PackageVersion>0.1.0-beta</PackageVersion>
    <PackageTags>AI;MCP;server;stdio;http;streamable-http;observability</PackageTags>
    <Description>An MCP server for qyl observability via stdio or Streamable HTTP.</Description>
  </PropertyGroup>

  <!-- RIDs only when publishing self-contained binaries (release artifacts,
       Docker multi-arch). During 'dotnet pack' (PackageType=McpServer) a
       RuntimeIdentifiers list forces the SDK to publish every RID into
       100+ MB per-RID packages; we want a single framework-dependent tool
       package < 5 MB. '$(IsPacking)' is 'true' inside the SDK's pack target. -->
  <PropertyGroup Condition="'$(IsPacking)' != 'true'">
    <RuntimeIdentifiers>win-x64;win-arm64;osx-arm64;linux-x64;linux-arm64;linux-musl-x64</RuntimeIdentifiers>
  </PropertyGroup>

  <!-- Self-contained single-file only when publishing to a specific RID
       (dotnet publish -r <RID>), never during pack. -->
  <PropertyGroup Condition="'$(RuntimeIdentifier)' != '' And '$(IsPacking)' != 'true'">
    <PublishSelfContained>true</PublishSelfContained>
    <PublishSingleFile>true</PublishSingleFile>
  </PropertyGroup>

  <ItemGroup>
    <Using Include="ANcpLua.Roslyn.Utilities"/>
    <Using Include="System.Diagnostics"/>
    <Using Include="qyl.mcp.Skills"/>
    <Using Include="qyl.mcp.Capabilities"/>
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="Clear.cs"/>
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App"/>
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/"/>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Landing\landing.html" LogicalName="qyl.mcp.Landing.landing.html"/>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="ANcpLua.Roslyn.Utilities"/>
    <!-- Qyl.Contracts is now a ProjectReference in the monorepo -->
    <!-- <PackageReference Include="Qyl.Contracts"/> -->
    <PackageReference Include="ModelContextProtocol"/>
    <PackageReference Include="ModelContextProtocol.AspNetCore"/>
    <PackageReference Include="OpenTelemetry.Api"/>
    <PackageReference Include="Microsoft.Extensions.AI"/>
    <PackageReference Include="Microsoft.Extensions.AI.OpenAI"/>
    <PackageReference Include="Microsoft.Extensions.Http.Diagnostics"/>
    <PackageReference Include="Microsoft.Extensions.Compliance.Redaction"/>
    <PackageReference Include="Microsoft.Extensions.Http.Resilience"/>
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer"/>
    <PackageReference Include="OpenAI"/>
  </ItemGroup>

  <!-- Source generator: compile-time tool manifest -->
  <ItemGroup>
    <ProjectReference Include="..\qyl.mcp.generators\qyl.mcp.generators.csproj"
                      OutputItemType="Analyzer" ReferenceOutputAssembly="false"/>
    <ProjectReference Include="..\qyl.contracts\qyl.contracts.csproj"/>
  </ItemGroup>

</Project>
