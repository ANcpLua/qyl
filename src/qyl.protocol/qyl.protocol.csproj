<Project Sdk="Microsoft.NET.Sdk">

  <!-- ═══════════════════════════════════════════════════════════════════════════════
       qyl.protocol — Shared Contracts (LEAF Project)

       Multi-targets for maximum compatibility:
       - net10.0: Latest features
       - net8.0: LTS
       - netstandard2.0: Maximum compatibility

       MUST NOT reference any other qyl.* project
       ═══════════════════════════════════════════════════════════════════════════════ -->

  <PropertyGroup>
    <TargetFrameworks>net10.0;net8.0;netstandard2.0</TargetFrameworks>
    <RootNamespace>Qyl.Protocol</RootNamespace>
    <Description>Shared types for qyl AI Observability Platform</Description>
    <PackageId>Qyl.Protocol</PackageId>
    <IsPackable>true</IsPackable>
  </PropertyGroup>

  <!-- Polyfills for older frameworks -->
  <PropertyGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
    <InjectIsExternalInitOnLegacy>true</InjectIsExternalInitOnLegacy>
    <InjectCallerAttributesOnLegacy>true</InjectCallerAttributesOnLegacy>
    <InjectDiagnosticAttributesOnLegacy>true</InjectDiagnosticAttributesOnLegacy>
  </PropertyGroup>

</Project>
