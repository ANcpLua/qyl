<Project Sdk="ANcpLua.NET.Sdk.Web">
  <PropertyGroup>
    <RootNamespace>Qyl.Collector</RootNamespace>
    <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
    <LangVersion>14</LangVersion>
    <InvariantGlobalization>true</InvariantGlobalization>
    <IsAotCompatible>false</IsAotCompatible>
    <InterceptorsNamespaces>$(InterceptorsNamespaces);Qyl.Instrumentation.Generators</InterceptorsNamespaces>
  </PropertyGroup>

  <PropertyGroup>
    <!-- Native AOT publish is opt-in: dotnet publish -p:QylAot=true -p:QylEmbedDashboard=false.
         QylAot (not PublishAot) is the CLI switch because a CLI global PublishAot=true would
         propagate into the two netstandard2.0 generator ProjectReferences below and fail with
         NETSDK1207; QylAot is a property nothing else reads, and PublishAot set HERE stays
         project-local. The collector reads DuckDB results only through boxed GetValue/Convert
         (DuckDbValueReader) and LIST(VARCHAR), which survive ILC without extra rooting; the
         executable owner of this lane is the native runtime smoke
         (eng/scripts/collector-aot-smoke.sh), not the analyzer. -->
    <PublishAot Condition="'$(QylAot)' == 'true'">true</PublishAot>
    <PublishTrimmed Condition="'$(QylAot)' == 'true'">true</PublishTrimmed>
    <SuppressTrimAnalysisWarnings Condition="'$(QylAot)' == 'true'">true</SuppressTrimAnalysisWarnings>
    <SuppressAotAnalysisWarnings Condition="'$(QylAot)' == 'true'">true</SuppressAotAnalysisWarnings>
    <!-- PublishAot enables the ConfigurationBindingGenerator interceptor, whose generated code
         uses ArgumentNullException.ThrowIfNull. The .editorconfig [*.g.cs] RS0030 exemption
         cannot match in-memory generated trees (pseudo paths outside the editorconfig cone),
         so the banned-API rule must be silenced for this lane only; the default JIT lane keeps
         full RS0030 enforcement, which catches any hand-written drift. -->
    <NoWarn Condition="'$(QylAot)' == 'true'">$(NoWarn);RS0030</NoWarn>
    <PublishAot Condition="'$(PublishAot)' == ''">false</PublishAot>
    <PublishTrimmed Condition="'$(PublishTrimmed)' == ''">false</PublishTrimmed>
  </PropertyGroup>

  <PropertyGroup>
    <!-- Release artifacts serve dashboard, API, and OTLP from one origin. -->
    <QylEmbedDashboard Condition="'$(QylEmbedDashboard)' == '' AND '$(Configuration)' == 'Release'">true</QylEmbedDashboard>
    <QylEmbedDashboard Condition="'$(QylEmbedDashboard)' == ''">false</QylEmbedDashboard>
  </PropertyGroup>

  <ItemGroup Condition="'$(QylEmbedDashboard)' == 'true' AND Exists('..\qyl.dashboard\dist\index.html')">
    <EmbeddedResource Include="..\qyl.dashboard\dist\**\*" LinkBase="wwwroot"/>
  </ItemGroup>

  <!-- Plain builds may omit the dashboard; an embed-enabled publish may not. -->
  <Target Name="QylRequireDashboardDistForPublish" BeforeTargets="PrepareForPublish"
          Condition="'$(QylEmbedDashboard)' == 'true' AND !Exists('..\qyl.dashboard\dist\index.html')">
    <Error Text="QylEmbedDashboard=true but services/qyl.dashboard/dist/index.html does not exist. Build the dashboard first (npm run build in services/qyl.dashboard) or publish with -p:QylEmbedDashboard=false."/>
  </Target>

  <ItemGroup>
    <PackageReference Include="DuckDB.NET.Data.Full"/>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Google.Protobuf"/>
    <PackageReference Include="Grpc.AspNetCore"/>
    <PackageReference Include="Grpc.Tools" PrivateAssets="all"/>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Diagnostics.Middleware"/>
    <PackageReference Include="Microsoft.Extensions.Telemetry"/>
    <PackageReference Include="Microsoft.Extensions.Telemetry.Abstractions"/>
    <PackageReference Include="Microsoft.Extensions.Compliance.Abstractions"/>
    <PackageReference Include="Microsoft.Extensions.Compliance.Redaction"/>
    <PackageReference Include="Microsoft.Extensions.Diagnostics.HealthChecks.Common"/>
    <PackageReference Include="Microsoft.Extensions.Diagnostics.HealthChecks.ResourceUtilization"/>
    <PackageReference Include="Microsoft.Extensions.Diagnostics.ResourceMonitoring"/>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.AsyncState"/>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Qyl.Api.Contracts"/>
    <PackageReference Include="Qyl.OpenTelemetry.AutoInstrumentation"/>
    <ProjectReference Include="..\..\internal\qyl.instrumentation\qyl.instrumentation.csproj"/>
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Qyl.Collector.Tests"/>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\internal\qyl.instrumentation.generators\qyl.instrumentation.generators.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false"/>
    <ProjectReference Include="..\..\internal\qyl.collector.storage.generators\qyl.collector.storage.generators.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false"/>
  </ItemGroup>

  <ItemGroup>
    <Protobuf Include="Protos/google/rpc/status.proto" ProtoRoot="Protos" GrpcServices="None"/>
    <Protobuf Include="Protos/opentelemetry/proto/common/v1/common.proto" ProtoRoot="Protos" GrpcServices="None"/>
    <Protobuf Include="Protos/opentelemetry/proto/resource/v1/resource.proto" ProtoRoot="Protos" GrpcServices="None"/>
    <Protobuf Include="Protos/opentelemetry/proto/trace/v1/trace.proto" ProtoRoot="Protos" GrpcServices="None"/>
    <Protobuf Include="Protos/opentelemetry/proto/logs/v1/logs.proto" ProtoRoot="Protos" GrpcServices="None"/>
    <Protobuf Include="Protos/opentelemetry/proto/profiles/v1development/profiles.proto" ProtoRoot="Protos" GrpcServices="None"/>
    <Protobuf Include="Protos/opentelemetry/proto/collector/trace/v1/trace_service.proto" ProtoRoot="Protos" GrpcServices="Server"/>
    <Protobuf Include="Protos/opentelemetry/proto/collector/logs/v1/logs_service.proto" ProtoRoot="Protos" GrpcServices="Server"/>
    <Protobuf Include="Protos/opentelemetry/proto/collector/profiles/v1development/profiles_service.proto" ProtoRoot="Protos" GrpcServices="Server"/>
  </ItemGroup>

  <Target Name="GenerateVersionConstant" BeforeTargets="CoreCompile">
    <PropertyGroup>
      <_VersionString>$(InformationalVersion)</_VersionString>
      <_VersionString Condition="'$(_VersionString)' == ''">$(Version)</_VersionString>
      <_VersionString Condition="'$(_VersionString)' == ''">0.0.0</_VersionString>
    </PropertyGroup>
    <ItemGroup>
      <Compile Include="$(IntermediateOutputPath)BuildVersion.g.cs"/>
    </ItemGroup>
    <WriteLinesToFile
      File="$(IntermediateOutputPath)BuildVersion.g.cs"
      Lines="namespace Qyl.Collector%3B&#10;&#10;internal static partial class BuildVersion&#10;{&#10;    public const string InformationalVersion = &quot;$(_VersionString)&quot;%3B&#10;}"
      Overwrite="true"/>
  </Target>

</Project>
