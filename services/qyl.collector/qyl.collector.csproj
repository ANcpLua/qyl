<Project Sdk="ANcpLua.NET.Sdk.Web">
  <!-- Build: 2026-01-28T17:10:00Z -->
  <PropertyGroup>
    <RootNamespace>Qyl.Collector</RootNamespace>
    <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
    <LangVersion>14</LangVersion>
    <InvariantGlobalization>true</InvariantGlobalization>
    <InterceptorsNamespaces>$(InterceptorsNamespaces);Qyl.Instrumentation.Generators</InterceptorsNamespaces>
    <QylDatabase>false</QylDatabase>
  </PropertyGroup>

  <PropertyGroup>
    <QylEmbedDashboard Condition="'$(QylEmbedDashboard)' == ''">false</QylEmbedDashboard>
  </PropertyGroup>

  <ItemGroup Condition="'$(QylEmbedDashboard)' == 'true' AND Exists('..\qyl.dashboard\dist\index.html')">
    <EmbeddedResource Include="..\qyl.dashboard\dist\**\*" LinkBase="wwwroot"/>
  </ItemGroup>

  <!-- Expose internals to test project -->
  <ItemGroup>
    <InternalsVisibleTo Include="Qyl.Collector.Tests"/>
  </ItemGroup>

  <ItemGroup>
    <Using Include="ANcpLua.Roslyn.Utilities"/>
  </ItemGroup>

  <!-- @typespec/http-server-csharp emits controllers + interfaces + support types into
       Generated/generated/{controllers,operations,lib}/. The parallel `models/` subtree
       duplicates the canonical types from @qyl/typespec-emit-csharp → Qyl.Contracts; keep
       it on disk for emitter idempotency but exclude from Compile. -->
  <ItemGroup>
    <Compile Remove="Generated/generated/models/**/*.cs"/>
  </ItemGroup>

  <!-- CS1573 / CS1591 scoping for the emitter's Generated subtree lives in
       services/qyl.collector/Generated/.editorconfig (file-scoped severity overrides
       beat csproj item metadata for analyzer diagnostics and keep the suppression
       discoverable at the offending file's location). -->

  <!-- DuckDB for embedded columnar storage -->
  <ItemGroup>
    <PackageReference Include="ANcpLua.Roslyn.Utilities"/>
    <PackageReference Include="DuckDB.NET.Data.Full"/>
  </ItemGroup>

  <!-- M.E.AI for IChatClient/IEmbeddingGenerator (Autofix, Triage, Insights) -->
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.AI"/>
  </ItemGroup>


  <!-- OTLP ingestion: gRPC hosting + OTel export for dynamic forwarding -->
  <ItemGroup>
    <PackageReference Include="Grpc.AspNetCore"/>
    <PackageReference Include="OpenTelemetry.Api"/>
    <PackageReference Include="OpenTelemetry.Exporter.OpenTelemetryProtocol"/>
    <PackageReference Include="System.IO.Hashing"/>
  </ItemGroup>

  <!-- .NET 10 Telemetry: Source generators, enrichment, redaction, buffering (in Telemetry pkg) -->
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Telemetry"/>
    <PackageReference Include="Microsoft.Extensions.Telemetry.Abstractions"/>
    <PackageReference Include="Microsoft.Extensions.Compliance.Abstractions"/>
    <PackageReference Include="Microsoft.Extensions.Compliance.Redaction"/>
    <PackageReference Include="Microsoft.AspNetCore.Diagnostics.Middleware"/>
    <!-- HealthChecks is transitive from HealthChecks.Common - explicit reference causes NU1510 -->
    <PackageReference Include="Microsoft.Extensions.Diagnostics.HealthChecks.Common"/>
    <PackageReference Include="Microsoft.Extensions.Diagnostics.HealthChecks.ResourceUtilization"/>
    <PackageReference Include="Microsoft.Extensions.Diagnostics.ResourceMonitoring"/>
  </ItemGroup>

  <!-- .NET 10 DI Lifecycle: AsyncState, object pooling -->
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.AsyncState"/>
  </ItemGroup>

  <!-- Auth: Keycloak JWT validation via JWKS -->
  <ItemGroup>
    <PackageReference Include="Microsoft.IdentityModel.JsonWebTokens"/>
  </ItemGroup>

  <!-- Core dependencies -->
  <ItemGroup>
    <ProjectReference Include="..\..\packages\Qyl.Contracts\qyl.contracts.csproj"/>
    <ProjectReference Include="..\..\packages\Qyl.SemanticConventions\Qyl.SemanticConventions.csproj"/>
    <ProjectReference Include="..\..\packages\Qyl.OpenTelemetry.SemanticConventions\Qyl.OpenTelemetry.SemanticConventions.csproj"/>
    <ProjectReference Include="..\..\packages\Qyl.OpenTelemetry.SemanticConventions.Incubating\Qyl.OpenTelemetry.SemanticConventions.Incubating.csproj"/>
    <ProjectReference Include="..\..\internal\qyl.instrumentation\qyl.instrumentation.csproj"/>
  </ItemGroup>

  <ItemGroup>
    <CompilerVisibleProperty Include="QylDatabase"/>
  </ItemGroup>

  <!-- Source generators (compile-time only) -->
  <ItemGroup>
    <ProjectReference Include="..\..\internal\qyl.instrumentation.generators\qyl.instrumentation.generators.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false"/>
    <ProjectReference Include="..\..\internal\qyl.collector.storage.generators\qyl.collector.storage.generators.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false"/>
    <ProjectReference Include="..\..\packages\Qyl.OpenTelemetry.SemanticConventions.Analyzers\Qyl.OpenTelemetry.SemanticConventions.Analyzers.csproj"
                      OutputItemType="Analyzer" ReferenceOutputAssembly="false" PrivateAssets="all"/>
  </ItemGroup>

  <ItemGroup>
    <Content Include="Storage/Migrations/*.sql">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </Content>
    <Content Update="data/model-pricing.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </Content>
  </ItemGroup>

  <!-- Compile-time version constant (avoids runtime reflection) -->
  <Target Name="GenerateVersionConstant" BeforeTargets="CoreCompile">
    <PropertyGroup>
      <_VersionString>$(InformationalVersion)</_VersionString>
      <_VersionString Condition="'$(_VersionString)' == ''">$(Version)</_VersionString>
      <_VersionString Condition="'$(_VersionString)' == ''">0.0.0</_VersionString>
    </PropertyGroup>
    <ItemGroup>
      <Compile Include="$(IntermediateOutputPath)BuildVersion.g.cs"/>
    </ItemGroup>
    <WriteLinesToFile
      File="$(IntermediateOutputPath)BuildVersion.g.cs"
      Lines="namespace Qyl.Collector%3B&#10;&#10;internal static partial class BuildVersion&#10;{&#10;    public const string InformationalVersion = &quot;$(_VersionString)&quot;%3B&#10;}"
      Overwrite="true"/>
  </Target>

</Project>
