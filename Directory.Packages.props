<Project>
  <Import Project="$(MSBuildThisFileDirectory)../framework/ANcpLua.NET.Sdk/src/Build/Common/Version.props"
          Condition="Exists('$(MSBuildThisFileDirectory)../framework/ANcpLua.NET.Sdk/src/Build/Common/Version.props')"/>
  <Import Project="Version.props"/>
  <PropertyGroup>
    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
  </PropertyGroup>
  <ItemGroup>
    <PackageVersion Include="OpenTelemetry.Api" Version="$(OpenTelemetryVersion)"/>
    <PackageVersion Include="OpenTelemetry.Exporter.OpenTelemetryProtocol" Version="$(OpenTelemetryVersion)"/>
    <PackageVersion Include="OpenTelemetry.Extensions.Hosting" Version="$(OpenTelemetryVersion)"/>
    <!-- Instrumentation packages do not share the SDK release line. -->
    <PackageVersion Include="OpenTelemetry.Instrumentation.AspNetCore" Version="1.16.0"/>
    <PackageVersion Include="OpenTelemetry.Instrumentation.Http" Version="$(OpenTelemetryAspNetCoreInstrumentationVersion)"/>
    <PackageVersion Include="OpenTelemetry.Instrumentation.Runtime" Version="$(OpenTelemetryAspNetCoreInstrumentationVersion)"/>
    <PackageVersion Include="Microsoft.Extensions.AI" Version="$(MicrosoftExtensionsAiVersion)"/>
    <PackageVersion Include="Microsoft.Extensions.AI.Evaluation" Version="$(MicrosoftExtensionsAiVersion)"/>
    <PackageVersion Include="Microsoft.Extensions.Hosting" Version="$(DotNetRuntimeVersion)"/>
    <PackageVersion Include="Microsoft.Extensions.Http.Resilience" Version="$(MicrosoftExtensionsVersion)"/>
    <PackageVersion Include="Microsoft.Extensions.Telemetry" Version="$(MicrosoftExtensionsVersion)"/>
    <PackageVersion Include="Microsoft.Extensions.Telemetry.Abstractions" Version="$(MicrosoftExtensionsVersion)"/>
    <PackageVersion Include="Microsoft.Extensions.Compliance.Abstractions" Version="$(MicrosoftExtensionsVersion)"/>
    <PackageVersion Include="Microsoft.Extensions.Compliance.Redaction" Version="$(MicrosoftExtensionsVersion)"/>
    <PackageVersion Include="Microsoft.Extensions.Diagnostics.HealthChecks.Common" Version="$(MicrosoftExtensionsVersion)"/>
    <PackageVersion Include="Microsoft.Extensions.Diagnostics.HealthChecks.ResourceUtilization" Version="$(MicrosoftExtensionsVersion)"/>
    <PackageVersion Include="Microsoft.Extensions.Diagnostics.ResourceMonitoring" Version="$(MicrosoftExtensionsVersion)"/>
    <PackageVersion Include="Microsoft.Extensions.AsyncState" Version="$(MicrosoftExtensionsVersion)"/>
    <PackageVersion Include="Microsoft.AspNetCore.Diagnostics.Middleware" Version="$(MicrosoftExtensionsVersion)"/>
    <PackageVersion Include="Microsoft.AspNetCore.OpenApi" Version="$(DotNetRuntimeVersion)"/>
    <!-- Microsoft.AspNetCore.OpenApi still generates assignments incompatible with Microsoft.OpenApi 3.x; 2.10.0 is patched for GHSA-v5pm-xwqc-g5wc. -->
    <PackageVersion Include="Microsoft.OpenApi" Version="2.10.0"/>
    <PackageVersion Include="Microsoft.Extensions.Hosting.Abstractions" Version="$(DotNetRuntimeVersion)"/>
    <PackageVersion Include="Microsoft.Extensions.ServiceDiscovery" Version="$(MicrosoftExtensionsVersion)"/>
    <PackageVersion Include="DuckDB.NET.Data.Full" Version="$(DuckDBVersion)"/>
    <PackageVersion Include="Google.Protobuf" Version="$(GoogleProtobufVersion)"/>
    <PackageVersion Include="Grpc.AspNetCore" Version="$(GrpcAspNetCoreVersion)"/>
    <PackageVersion Include="Grpc.Tools" Version="$(GrpcToolsVersion)"/>
    <PackageVersion Include="ANcpLua.Roslyn.Utilities" Version="$(ANcpLuaRoslynUtilitiesVersion)"/>
    <PackageVersion Include="ANcpLua.Roslyn.Utilities.Sources" Version="$(ANcpLuaRoslynUtilitiesVersion)"/>
    <PackageVersion Include="ANcpLua.Agents" Version="$(ANcpLuaAgentsVersion)"/>
    <PackageVersion Include="Microsoft.Agents.AI" Version="$(MicrosoftAgentsAIVersion)"/>
    <PackageVersion Include="Microsoft.Agents.AI.Hosting" Version="$(MicrosoftAgentsAIHostingVersion)"/>
    <PackageVersion Include="Microsoft.CodeAnalysis.CSharp" Version="5.6.0"/>
    <PackageVersion Include="Nuke.Common" Version="$(NukeVersion)"/>
    <PackageVersion Include="Nuke.Components" Version="$(NukeVersion)"/>
    <!-- Override vulnerable Nuke.Common transitives. -->
    <PackageVersion Include="NuGet.Packaging" Version="7.6.0"/>
    <PackageVersion Include="System.Security.Cryptography.Xml" Version="10.0.9"/>
    <PackageVersion Include="Spectre.Console" Version="$(SpectreConsoleVersion)"/>
    <!-- Core avoids the reflection-based server hosting in the full MCP package. -->
    <PackageVersion Include="ModelContextProtocol.Core" Version="1.4.1"/>
    <PackageVersion Include="xunit.v3.mtp-v2" Version="3.2.2"/>
    <PackageVersion Include="McMaster.Extensions.CommandLineUtils" Version="5.1.0"/>
    <!-- Nuke.ProjectModel requires this floor under transitive pinning. -->
    <PackageVersion Include="Microsoft.Build" Version="18.7.1"/>
    <PackageVersion Include="Microsoft.NETFramework.ReferenceAssemblies" Version="1.0.3"/>
    <PackageVersion Include="Valleysoft.DockerfileModel" Version="2.0.0"/>
    <PackageVersion Include="YamlDotNet" Version="18.1.0"/>
    <PackageVersion Include="Qyl.OpenTelemetry.AutoInstrumentation" Version="5.2.0"/>
    <PackageVersion Include="Qyl.OpenTelemetry.SemanticConventions" Version="3.5.1"/>
    <PackageVersion Include="Qyl.OpenTelemetry.SemanticConventions.Incubating" Version="3.5.1"/>
    <PackageVersion Include="Qyl.OpenTelemetry.SemanticConventions.SourceGeneration" Version="3.5.1"/>
    <PackageVersion Include="Qyl.Api.Contracts" Version="$(QylApiContractsVersion)"/>
  </ItemGroup>
  <ItemGroup>
    <PackageDownload Include="Versionize" Version="[$(VersionizeVersion)]"/>
  </ItemGroup>
</Project>
